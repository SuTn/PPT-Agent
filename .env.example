# PPT-Agent Configuration
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────
# Format: "<provider>:<model_name>"
# Supported providers: openai, anthropic
#
# Examples:
#   openai:gpt-4o                  → OpenAI
#   openai:deepseek-chat           → DeepSeek  (set PPT_AGENT_OPENAI_BASE_URL)
#   openai:qwen-plus               → Qwen      (set PPT_AGENT_OPENAI_BASE_URL)
#   openai:moonshot-v1-8k          → Moonshot  (set PPT_AGENT_OPENAI_BASE_URL)
#   anthropic:claude-sonnet-4-6    → Anthropic Claude
PPT_AGENT_MODEL=openai:gpt-4o

# ── OpenAI-compatible API ─────────────────────────────────────
# Works with: OpenAI, DeepSeek, Qwen, Moonshot, Ollama, vLLM, etc.
# Leave base_url empty for official OpenAI API.
PPT_AGENT_OPENAI_API_KEY=sk-xxx
PPT_AGENT_OPENAI_BASE_URL=

# ── Anthropic-compatible API ──────────────────────────────────
# Leave base_url empty for official Anthropic API.
PPT_AGENT_ANTHROPIC_API_KEY=sk-ant-xxx
PPT_AGENT_ANTHROPIC_BASE_URL=

# ── Web Search (optional) ─────────────────────────────────────
# Options: tavily (API, fast, requires key) | playwright (browser, no key needed) | empty (disabled)
PPT_AGENT_SEARCH_PROVIDER=tavily
PPT_AGENT_TAVILY_API_KEY=

# ── Output ────────────────────────────────────────────────────
PPT_AGENT_OUTPUT_DIR=./output
