# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Default model for PPT generation
# Supports: openai:gpt-4o, anthropic:claude-sonnet-4-6, openrouter:..., vllm:..., zhipu:...
PPT_AGENT_MODEL=anthropic:claude-sonnet-4-6

# VLLM (OpenAI-compatible)
PPT_AGENT_VLLM_BASE_URL=http://localhost:8000/v1
PPT_AGENT_VLLM_API_KEY=empty

# ZhipuAI (GLM)
PPT_AGENT_ZHIPU_API_KEY=
PPT_AGENT_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# OpenRouter (access to many models via unified API)
PPT_AGENT_OPENROUTER_API_KEY=

# Web Search (optional, enhances research with real-time data)
PPT_AGENT_SEARCH_PROVIDER=tavily
PPT_AGENT_TAVILY_API_KEY=

# Output directory
PPT_OUTPUT_DIR=./output
